# Backend API URL (default to backend server)
EXPO_PUBLIC_API_URL=http://192.168.100.136:8080

# RevenueCat Public API Keys (Replace these with your actual keys from RevenueCat Dashboard)
# Create your keys under Project Settings > API Keys in RevenueCat.
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_your_actual_apple_public_key
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_your_actual_google_public_key
